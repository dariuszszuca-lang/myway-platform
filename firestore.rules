rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === UŻYTKOWNICY ===
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }
    match /users/{userId}/journal/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }
    match /users/{userId}/motivations/{motId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // === MATERIAŁY ===
    // Wszyscy zalogowani czytają, terapeuta dodaje/usuwa
    match /materials/{materialId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }

    // === SESJE ===
    // Wszyscy zalogowani czytają, terapeuta tworzy/usuwa, pacjent bookuje (update)
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'therapist';
      allow update: if request.auth != null;
    }

    // Blokada reszty
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
